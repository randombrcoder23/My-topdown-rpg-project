extends CharacterBody2D

signal hp_alterado(hp)

@export var direction = Vector2.ZERO
@onready var animation = $AnimatedSprite2D
@export var speed = 500
@export var accel = 2000
@export var frict = 2400
@export var dashenabled = true
@export var maxhp = 100
@export var currenthp = 100
@export var animenabled = true
@export var dashing = false

func _process(_delta: float) -> void:
	
	if currenthp == 0:
		animenabled = false
		
	if animenabled:
		if dashing == false:
			if direction.y > 0:
				$AnimatedSprite2D.play("walk_down")
		
			elif  direction.y < 0:
				$AnimatedSprite2D.play("walk_up")
		
			elif  direction.x > 0:
				$AnimatedSprite2D.play("walk_left")
		
			elif  direction.x < 0:
				$AnimatedSprite2D.play("walk_right")
		
			else:
				$AnimatedSprite2D.play("idle")
	else:
		$AnimatedSprite2D.play("death")
		await get_tree().create_timer(0.7).timeout
		self.queue_free()
	
	if Input.is_action_just_pressed("Dano"):
		tomar_dano()
		
	if dashenabled:
		if Input.is_action_just_pressed("ui_accept"):
			dash()
		
		
func _physics_process(_delta: float) -> void:
	
	direction = Input.get_vector("A", "D", "W", "S")
	
	if direction:
		velocity = velocity.move_toward(direction * speed, accel * _delta)
	else:
		velocity = velocity.move_toward(Vector2.ZERO, frict * _delta)
		
	move_and_slide()

func dash():
	dashing = true
	speed *= 15
	accel *= 2
	dashenabled = false
	$AnimatedSprite2D.play("dash")
	await get_tree().create_timer(0.3).timeout
	speed = 300
	accel = 2000
	dashing = false
	await get_tree().create_timer(2.3).timeout
	dashenabled = true
	
func tomar_dano():
	currenthp -= 10
	currenthp = clamp(currenthp, 0, maxhp) 
	hp_alterado.emit(currenthp) 
	print("sofreu dano! hp atual: ", currenthp)


